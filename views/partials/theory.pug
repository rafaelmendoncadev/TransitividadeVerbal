section.section-block#teoria
  h2.section-title Teoria

  article.theory-card#trans-vs-intrans
    h3.theory-card__title Transitivos e Intransitivos
    p.theory-card__text
      | Verbos
      strong  transitivos
      |  exigem complemento verbal (objeto direto ou indireto) para completar o sentido.
      |  Verbos
      strong  intransitivos
      |  têm sentido completo por si só e não exigem complemento.
    .example-box
      p
        span.example-box__label Exemplo contrastivo:
      p
        | Eu preciso 
        span.obj-indirect de um livro
        | . — transitivo (VTI)
      p.example-note
        em precisa
        |  = VTI;
        em de um livro
        |  = objeto indireto
    .example-box
      p Eu preciso. — intransitivo (VI)
      p.example-note
        | O verbo tem sentido completo; falta apenas indicar 
        em o quê
        |  se precisa.

  .theory-grid.theory-grid--2
    article.theory-card#vtd
      h3.theory-card__title Verbo Transitivo Direto (VTD)
      p.theory-card__text Exige objeto direto (OD), ligado ao verbo sem preposição obrigatória.
      .example-box
        p
          | Eu estudei 
          span.obj-direct Língua Portuguesa e Matemática
          | .
        p.example-note
          em estudei
          |  = VTD;
          em Língua Portuguesa e Matemática
          |  = OD
      .example-box
        p
          | Ela ganhou 
          span.obj-direct um tênis de aniversário
          | .
      .example-box
        p
          | Os exercícios exigem 
          span.obj-direct força
          | .

    article.theory-card#vti
      h3.theory-card__title Verbo Transitivo Indireto (VTI)
      p.theory-card__text Exige objeto indireto (OI), sempre introduzido por preposição.
      .example-box
        p
          | As plantas necessitam 
          span.obj-indirect de água
          | .
        p.example-note
          em necessitam
          |  = VTI;
          em de água
          |  = OI
      .example-box
        p
          | O aluno 
          span.verb-highlight precisa
          |  
          span.obj-indirect de ajuda
          | .
      .example-box
        p
          | Não devemos depender 
          span.obj-indirect de nossos pais
          | .

    article.theory-card#vtdi
      h3.theory-card__title Verbo Transitivo Direto-Indireto (VTDI)
      p.theory-card__text Possui objeto direto e objeto indireto simultaneamente.
      .example-box
        p
          | Ela emprestou 
          span.obj-direct o livro
          |  
          span.obj-indirect a um colega de sala
          | .
      .example-box
        p
          | Entreguei 
          span.obj-direct o dinheiro
          |  
          span.obj-indirect à funcionária
          | .
      .example-box
        p
          | Mandei 
          span.obj-direct o e-mail
          |  
          span.obj-indirect para você
          |  ontem.

    article.theory-card#vi
      h3.theory-card__title Verbo Intransitivo (VI)
      p.theory-card__text Não exige complemento verbal; adjuntos adverbiais não são complementos.
      .example-box
        p João chegou tarde.
        p.example-note
          em chegou
          |  = VI;
          em tarde
          |  = adjunto adverbial de tempo
      .example-box
        p Nós saímos mais cedo.
      .example-box
        p Ele dormiu muito essa noite.

    article.theory-card#vl
      h3.theory-card__title Verbo de Ligação (VL)
      p.theory-card__text Liga o sujeito ao predicativo do sujeito (característica, estado ou qualidade).
      .example-box
        p Ele está feliz com os resultados.
        p.example-note
          em está
          |  = VL;
          em feliz
          |  = predicativo do sujeito
      .example-box
        p
          | Depois de tudo, virou 
          span.obj-indirect um santo
          |  na cidade.
      .example-box
        p Eu continuo atento ao trabalho.

  article.theory-card#complemento
