  article.theory-card#preposicoes
    h3.theory-card__title Preposições Essenciais
    p.theory-card__text Preposições frequentes na regência de objetos indiretos:
    table.data-table.data-table--compact
      tbody
        tr
          td a
          td após
          td com
          td contra
        tr
          td ante
          td até
          td de
          td desde
        tr
          td em
          td entre
          td para
          td perante
        tr
          td por
          td sem
          td sob
          td sobre
        tr
          td(colspan='4') trás

  article.theory-card#dicas
    h3.theory-card__title Dicas Práticas para Análise
    ol
      li
        strong Identifique o verbo
        |  — encontre a ação ou estado central da frase.
      li
        strong Procure complemento
        |  — pergunte “verbo + quê?” ou “verbo + a/de/para + quê?”.
      li
        strong Verifique a preposição
        |  — sem preposição obrigatória → provável OD (VTD); com preposição → OI (VTI).
      li
        strong Distinga VL
        |  — se o termo após o verbo indica característica do sujeito, é predicativo (VL).
    .example-box
      p
        span.example-box__label Análise rápida:
        |  “Comprei o livro ontem à tarde.”
      p
        span.verb-highlight Comprei
        |  (VTD) +
        span.obj-direct o livro
        |  (OD) +
        em ontem à tarde
        |  (adjunto adverbial)
